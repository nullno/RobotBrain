# kv/root.kv
#:import COLORS app.theme.COLORS

FloatLayout:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # 主界面容器- 初始隐藏,配网完成后加载内容并显示
    FloatLayout:
        id: main_content
        opacity: 0
        disabled: True