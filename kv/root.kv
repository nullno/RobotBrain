# kv/root.kv
#:import COLORS app.theme.COLORS

FloatLayout:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    # 主界面容器 - 初始隐藏,配网完成后显示
    FloatLayout:
        id: main_content
        opacity: 0
        disabled: True

        CameraView:
            id: camera_view
            opacity: 0

        GyroPanel:
            id: gyro_panel
            size_hint: None, None
            size: dp(90), dp(120)
            pos_hint: {"x": 0.01, "top": 0.99}

        Esp32Indicator:
            id: esp32_indicator
            size_hint: None, None
            size: dp(120), dp(28)
            pos_hint: {"right": 0.99, "top": 0.98}

        RobotFace:
            id: face
            camera_view: camera_view
            size_hint: (0.8, 0.6)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}

        DebugPanel:
            id: debug_panel

        RuntimeStatusPanel:
            id: runtime_status
            pos_hint: {"x": 0.01, "y": 0.08}

        Button:
            size_hint: None, None
            size: dp(20), dp(20)
            pos_hint: {"right": 0.98, "y": 0.06}
            background_normal: ""
            background_down: ""
            on_release: app.root_widget.ids.debug_panel.open_debug()
            Image:
                source: "assets/icon_debug.png"
                size: self.parent.size
                pos: self.parent.pos